# =============================================================================
# TradeKai .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Environment & Secrets
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.env
!.env.example

# -----------------------------------------------------------------------------
# Go (Backend)
# -----------------------------------------------------------------------------
# Compiled binaries
backend/bin/
backend/*.exe
backend/*.out
backend/*.test

# Go build cache
/tmp/
*.sum.bak

# Air live-reload tmp dir
backend/tmp/

# Test coverage
*.coverprofile
coverage.out
coverage.html

# sqlc generated files (regenerate with `make sqlc`)
backend/internal/store/db/

# -----------------------------------------------------------------------------
# Angular (Frontend)
# -----------------------------------------------------------------------------
# Dependencies
frontend/node_modules/

# Angular build output
frontend/dist/
frontend/.angular/cache/
frontend/.angular/

# Test & coverage output
frontend/coverage/

# Karma/Jasmine
frontend/.chrome/

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
# Ignore local override compose files
deployments/docker-compose.override.yml

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Local Postgres/TimescaleDB data volumes
pgdata/
timescaledata/
*.sql.bak

# -----------------------------------------------------------------------------
# IDE & Editor
# -----------------------------------------------------------------------------
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
.DS_Store
desktop.ini

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.tmp
*.bak
*.orig
