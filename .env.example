# Server
SERVER_PORT=8080
SERVER_MODE=development  # development | production

# Database
DATABASE_URL=postgres://tradekai:tradekai@localhost:5432/tradekai?sslmode=disable
DATABASE_MAX_CONNECTIONS=25
DATABASE_MIN_CONNECTIONS=5

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h  # 7 days

# Alpaca
ALPACA_API_KEY=your-alpaca-api-key
ALPACA_API_SECRET=your-alpaca-api-secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_FEED=iex  # iex | sip

# Market Data Provider
# Set to "simulated" for local dev without Alpaca keys
# Set to "alpaca" to use real Alpaca market data
MARKET_DATA_PROVIDER=simulated

# Order Executor
# Set to "simulated" for local dev without Alpaca keys
# Set to "alpaca" to use real Alpaca order execution
ORDER_EXECUTOR=simulated

# Risk
RISK_MAX_POSITION_SIZE=100
RISK_MAX_OPEN_ORDERS=10
RISK_DAILY_LOSS_LIMIT=1000.00
RISK_DUPLICATE_TRADE_WINDOW=60s
RISK_MAX_PORTFOLIO_EXPOSURE=50000.00

# Logging
LOG_LEVEL=info  # debug | info | warn | error
LOG_FORMAT=console  # console | json

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:4200

# Rate limiting
RATE_LIMIT_API=100      # requests per minute
RATE_LIMIT_AUTH=10      # requests per minute

# Observability
OTEL_SERVICE_NAME=tradekai
OTEL_ENDPOINT=localhost:4317
PROMETHEUS_ENABLED=true
